# ============================================================
# Fluency AI — Monorepo Environment
# Copie este arquivo para .env e preencha os valores
# ============================================================

# --- App ---
APP_ENV=local
APP_KEY=                        # gerado em: php artisan key:generate

# --- Frontend URL (para CORS do backend) ---
FRONTEND_URL=http://localhost:4200

# --- PostgreSQL ---
DB_DATABASE=fluency_ai_backend
DB_USERNAME=fluency
DB_PASSWORD=fluency_secret

# --- Redis ---
REDIS_PASSWORD=null

# --- pgAdmin (opcional) ---
PGADMIN_DEFAULT_EMAIL=admin@fluency.com
PGADMIN_DEFAULT_PASSWORD=admin123

# --- Anthropic (para laravel/ai SDK) ---
ANTHROPIC_API_KEY=

# --- Supabase (squad) ---
SUPABASE_URL=https://kyhkruedsilimzrlhkdc.supabase.co
SUPABASE_ANON_KEY=
